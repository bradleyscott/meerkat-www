---
import Layout from './Layout.astro';
import { getNav } from '../lib/content';
import type { NavItem } from '../lib/content';

interface Props {
  title: string;
  breadcrumbs?: { label: string; href: string }[];
}

const { title, breadcrumbs = [] } = Astro.props;
const nav = getNav();
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/docs';
---

<Layout title={`${title} — Meerkat Docs`}>
  <!-- Navigation -->
  <nav class="nav">
    <div class="nav-left">
      <a href="/" class="nav-logo">
        <img src="/logo-mark.svg" alt="Meerkat" width="32" height="32" />
        <span>meerkat</span>
      </a>
      <span class="nav-sep">/</span>
      <a href="/docs" class="nav-docs-link">docs</a>
    </div>
    <div class="nav-right">
      <button class="sidebar-toggle" id="sidebar-toggle" aria-label="Toggle navigation">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
      </button>
      <a href="https://github.com/bradleyscott/meerkat" class="nav-cta" target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        GitHub
      </a>
    </div>
  </nav>

  <div class="docs-shell">
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-inner">
        {nav.map((section) => (
          <div class="sidebar-section">
            {section.children ? (
              <>
                <a
                  href={section.href}
                  class:list={['sidebar-heading', { active: currentPath === section.href.replace(/\/$/, '') }]}
                >
                  {section.label}
                </a>
                <ul class="sidebar-list">
                  {section.children.map((child) => (
                    <li>
                      {child.children ? (
                        <>
                          <span class="sidebar-group-label">{child.label}</span>
                          <ul class="sidebar-sublist">
                            {child.children.map((sub) => (
                              <li>
                                <a
                                  href={sub.href}
                                  class:list={['sidebar-link', { active: currentPath === sub.href.replace(/\/$/, '') }]}
                                >
                                  {sub.label}
                                </a>
                              </li>
                            ))}
                          </ul>
                        </>
                      ) : (
                        <a
                          href={child.href}
                          class:list={['sidebar-link', { active: currentPath === child.href.replace(/\/$/, '') }]}
                        >
                          {child.label}
                        </a>
                      )}
                    </li>
                  ))}
                </ul>
              </>
            ) : (
              <a
                href={section.href}
                class:list={['sidebar-heading', { active: currentPath === section.href.replace(/\/$/, '') }]}
              >
                {section.label}
              </a>
            )}
          </div>
        ))}
      </div>
    </aside>

    <!-- Overlay for mobile -->
    <div class="sidebar-overlay" id="sidebar-overlay"></div>

    <!-- Main content -->
    <main class="docs-main">
      {breadcrumbs.length > 1 && (
        <nav class="breadcrumbs" aria-label="Breadcrumb">
          {breadcrumbs.map((crumb, i) => (
            <>
              {i > 0 && <span class="breadcrumb-sep">/</span>}
              {i === breadcrumbs.length - 1 ? (
                <span class="breadcrumb-current">{crumb.label}</span>
              ) : (
                <a href={crumb.href} class="breadcrumb-link">{crumb.label}</a>
              )}
            </>
          ))}
        </nav>
      )}

      <article class="prose">
        <slot />
      </article>
    </main>
  </div>
</Layout>

<script>
  const toggle = document.getElementById('sidebar-toggle')!;
  const sidebar = document.getElementById('sidebar')!;
  const overlay = document.getElementById('sidebar-overlay')!;

  function closeSidebar() {
    sidebar.classList.remove('open');
    overlay.classList.remove('open');
  }

  toggle.addEventListener('click', () => {
    sidebar.classList.toggle('open');
    overlay.classList.toggle('open');
  });

  overlay.addEventListener('click', closeSidebar);

  // Close on nav click (mobile)
  sidebar.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', closeSidebar);
  });
</script>

<style>
  /* ---- Nav ---- */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1.5rem;
    height: 56px;
    backdrop-filter: blur(16px) saturate(1.4);
    -webkit-backdrop-filter: blur(16px) saturate(1.4);
    background: rgba(27, 43, 58, 0.85);
    border-bottom: 1px solid rgba(212, 149, 106, 0.08);
  }

  .nav-left, .nav-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 1.05rem;
    letter-spacing: -0.5px;
    color: var(--cream);
  }

  .nav-sep {
    color: rgba(100, 116, 139, 0.4);
    font-weight: 300;
    font-size: 1.2rem;
  }

  .nav-docs-link {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--slate);
  }

  .nav-docs-link:hover {
    color: var(--cream);
  }

  .nav-cta {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.85rem;
    border-radius: 8px;
    border: 1px solid rgba(212, 149, 106, 0.2);
    color: var(--tawny);
    font-weight: 600;
    font-size: 0.85rem;
    transition: all 0.2s;
  }

  .nav-cta:hover {
    background: rgba(212, 149, 106, 0.1);
    border-color: rgba(212, 149, 106, 0.35);
  }

  .sidebar-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--slate);
    cursor: pointer;
    padding: 0.25rem;
    border-radius: 6px;
  }

  .sidebar-toggle:hover {
    color: var(--cream);
    background: rgba(255, 255, 255, 0.05);
  }

  /* ---- Shell ---- */
  .docs-shell {
    display: flex;
    min-height: 100vh;
    padding-top: 56px;
  }

  /* ---- Sidebar ---- */
  .sidebar {
    position: fixed;
    top: 56px;
    left: 0;
    bottom: 0;
    width: 272px;
    overflow-y: auto;
    border-right: 1px solid rgba(245, 230, 211, 0.06);
    background: rgba(20, 32, 44, 0.5);
    z-index: 50;
  }

  .sidebar-inner {
    padding: 1.5rem 0 3rem;
  }

  .sidebar-section {
    margin-bottom: 0.25rem;
  }

  .sidebar-heading {
    display: block;
    padding: 0.5rem 1.25rem;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--slate);
    transition: color 0.15s;
  }

  .sidebar-heading:hover {
    color: var(--cream);
  }

  .sidebar-heading.active {
    color: var(--tawny);
  }

  .sidebar-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sidebar-group-label {
    display: block;
    padding: 0.6rem 1.25rem 0.25rem 1.75rem;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: rgba(100, 116, 139, 0.6);
  }

  .sidebar-sublist {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sidebar-link {
    display: block;
    padding: 0.35rem 1.25rem 0.35rem 1.75rem;
    font-size: 0.88rem;
    color: rgba(245, 230, 211, 0.55);
    transition: all 0.15s;
    border-left: 2px solid transparent;
  }

  .sidebar-sublist .sidebar-link {
    padding-left: 2.5rem;
    font-size: 0.85rem;
  }

  .sidebar-link:hover {
    color: var(--cream);
    background: rgba(245, 230, 211, 0.03);
  }

  .sidebar-link.active {
    color: var(--tawny);
    border-left-color: var(--tawny);
    background: rgba(212, 149, 106, 0.06);
  }

  .sidebar-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 40;
  }

  /* ---- Main content ---- */
  .docs-main {
    flex: 1;
    margin-left: 272px;
    padding: 2.5rem 3rem 4rem;
    max-width: 820px;
    min-width: 0;
  }

  /* ---- Breadcrumbs ---- */
  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 2rem;
    font-size: 0.82rem;
    flex-wrap: wrap;
  }

  .breadcrumb-link {
    color: var(--slate);
    transition: color 0.15s;
  }

  .breadcrumb-link:hover {
    color: var(--tawny);
  }

  .breadcrumb-sep {
    color: rgba(100, 116, 139, 0.3);
  }

  .breadcrumb-current {
    color: var(--cream);
    font-weight: 500;
  }

  /* ---- Prose styling ---- */
  .prose {
    line-height: 1.75;
    font-size: 1rem;
  }

  .prose :global(h1) {
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.75px;
    margin-bottom: 1.25rem;
    line-height: 1.2;
  }

  .prose :global(h2) {
    font-size: 1.45rem;
    font-weight: 700;
    letter-spacing: -0.3px;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(245, 230, 211, 0.06);
  }

  .prose :global(h3) {
    font-size: 1.15rem;
    font-weight: 700;
    margin-top: 1.75rem;
    margin-bottom: 0.6rem;
  }

  .prose :global(h4) {
    font-size: 1rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--sand);
  }

  .prose :global(p) {
    color: rgba(245, 230, 211, 0.75);
    margin-bottom: 1rem;
  }

  .prose :global(a) {
    color: var(--tawny);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: rgba(212, 149, 106, 0.3);
  }

  .prose :global(a:hover) {
    color: var(--alert-amber);
    text-decoration-color: var(--alert-amber);
  }

  .prose :global(strong) {
    color: var(--cream);
    font-weight: 600;
  }

  .prose :global(em) {
    color: var(--alert-amber);
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
    color: rgba(245, 230, 211, 0.75);
  }

  .prose :global(li) {
    margin-bottom: 0.5rem;
  }

  .prose :global(li > ul),
  .prose :global(li > ol) {
    margin-top: 0.35rem;
    margin-bottom: 0.35rem;
  }

  .prose :global(code) {
    font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
    font-size: 0.87em;
    color: var(--tawny);
    background: rgba(212, 149, 106, 0.1);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .prose :global(pre) {
    margin: 1.25rem 0;
    padding: 1.25rem;
    border-radius: 12px;
    background: rgba(10, 18, 26, 0.7);
    border: 1px solid rgba(245, 230, 211, 0.07);
    overflow-x: auto;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    border-radius: 0;
    color: var(--sand);
    font-size: 0.88rem;
    line-height: 1.7;
  }

  .prose :global(blockquote) {
    margin: 1.25rem 0;
    padding: 0.75rem 1.25rem;
    border-left: 3px solid var(--tawny);
    background: rgba(212, 149, 106, 0.05);
    border-radius: 0 8px 8px 0;
  }

  .prose :global(blockquote p) {
    margin-bottom: 0;
    color: rgba(245, 230, 211, 0.7);
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid rgba(245, 230, 211, 0.08);
    margin: 2rem 0;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    margin: 1.25rem 0;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(245, 230, 211, 0.07);
  }

  .prose :global(thead) {
    background: rgba(245, 230, 211, 0.04);
  }

  .prose :global(th) {
    text-align: left;
    padding: 0.65rem 0.85rem;
    font-weight: 600;
    color: var(--sand);
    border-bottom: 1px solid rgba(245, 230, 211, 0.08);
  }

  .prose :global(td) {
    padding: 0.55rem 0.85rem;
    color: rgba(245, 230, 211, 0.7);
    border-bottom: 1px solid rgba(245, 230, 211, 0.04);
  }

  .prose :global(tr:last-child td) {
    border-bottom: none;
  }

  .prose :global(img) {
    max-width: 100%;
    border-radius: 8px;
  }

  /* ---- Responsive ---- */
  @media (max-width: 900px) {
    .sidebar-toggle {
      display: flex;
    }

    .sidebar {
      transform: translateX(-100%);
      transition: transform 0.25s ease;
      background: rgba(20, 32, 44, 0.97);
      backdrop-filter: blur(16px);
    }

    .sidebar.open {
      transform: translateX(0);
    }

    .sidebar-overlay.open {
      display: block;
    }

    .docs-main {
      margin-left: 0;
      padding: 2rem 1.5rem 3rem;
    }
  }

  @media (max-width: 640px) {
    .docs-main {
      padding: 1.5rem 1rem 3rem;
    }

    .nav-cta span {
      display: none;
    }
  }
</style>
