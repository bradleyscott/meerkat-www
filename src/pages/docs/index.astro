---
import DocsLayout from '../../layouts/DocsLayout.astro';
import { getReadme } from '../../lib/content';

const page = getReadme();
---

<DocsLayout title="Documentation" breadcrumbs={page.breadcrumbs}>
  <div class="overview-logo">
    <img src="/logo.svg" alt="Meerkat mascot" width="120" height="120" />
    <h1 class="overview-title">meerkat</h1>
  </div>
  <Fragment set:html={page.html} />
</DocsLayout>

<style>
  .overview-logo {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .overview-title {
    margin-top: 0.75rem;
    margin-bottom: 0;
    font-size: 2rem;
  }
</style>
