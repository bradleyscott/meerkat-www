<script>
  const svg = document.getElementById('hero-logo') as unknown as SVGSVGElement | null;
  if (svg) {
    const pupilL = document.getElementById('pupil-l')!;
    const pupilR = document.getElementById('pupil-r')!;
    const highlightL = document.getElementById('highlight-l')!;
    const highlightR = document.getElementById('highlight-r')!;

    // Eye white centers in SVG inner coordinate space
    const eyes = {
      left:  { cx: 230, cy: 170 },
      right: { cx: 282, cy: 170 },
    };

    // Default rest offsets (original pupil/highlight positions relative to eye center)
    const PUPIL_REST = { dx: 3, dy: -2 };
    const HIGHLIGHT_REST = { dx: 6, dy: -5 };

    // Max travel: eye white r(14) minus pupil r(8) = 6
    const MAX_PUPIL = 6;
    // Highlight travels a bit further for parallax depth
    const MAX_HIGHLIGHT = 8;

    // Smoothing: 13% per frame → ~0.3s to settle
    const LERP = 0.13;

    // Current and target positions for each element
    let curL = { px: eyes.left.cx + PUPIL_REST.dx, py: eyes.left.cy + PUPIL_REST.dy, hx: eyes.left.cx + HIGHLIGHT_REST.dx, hy: eyes.left.cy + HIGHLIGHT_REST.dy };
    let curR = { px: eyes.right.cx + PUPIL_REST.dx, py: eyes.right.cy + PUPIL_REST.dy, hx: eyes.right.cx + HIGHLIGHT_REST.dx, hy: eyes.right.cy + HIGHLIGHT_REST.dy };
    let tgtL = { ...curL };
    let tgtR = { ...curR };

    let active = false;
    let running = false;

    function restTarget(eye: { cx: number; cy: number }) {
      return {
        px: eye.cx + PUPIL_REST.dx, py: eye.cy + PUPIL_REST.dy,
        hx: eye.cx + HIGHLIGHT_REST.dx, hy: eye.cy + HIGHLIGHT_REST.dy,
      };
    }

    // Convert page coords → SVG inner group coords
    function toInner(pageX: number, pageY: number) {
      const pt = svg.createSVGPoint();
      pt.x = pageX;
      pt.y = pageY;
      const ctm = svg.getScreenCTM();
      if (!ctm) return { x: 256, y: 256 };
      const s = pt.matrixTransform(ctm.inverse());
      // Invert the group transform: scale(1.25) centered at (256,256)
      return { x: (s.x - 256) / 1.25 + 256, y: (s.y - 256) / 1.25 + 256 };
    }

    // Constrain movement toward cursor within a max radius
    function constrain(ecx: number, ecy: number, tx: number, ty: number, maxR: number) {
      const dx = tx - ecx;
      const dy = ty - ecy;
      const dist = Math.sqrt(dx * dx + dy * dy);
      if (dist === 0) return { x: ecx, y: ecy };
      const ratio = Math.min(dist, 200) / 200;
      const travel = ratio * maxR;
      return { x: ecx + (dx / dist) * travel, y: ecy + (dy / dist) * travel };
    }

    function updateTargets(pageX: number, pageY: number) {
      const c = toInner(pageX, pageY);
      const pl = constrain(eyes.left.cx, eyes.left.cy, c.x, c.y, MAX_PUPIL);
      const hl = constrain(eyes.left.cx, eyes.left.cy, c.x, c.y, MAX_HIGHLIGHT);
      tgtL = { px: pl.x, py: pl.y, hx: hl.x, hy: hl.y };
      const pr = constrain(eyes.right.cx, eyes.right.cy, c.x, c.y, MAX_PUPIL);
      const hr = constrain(eyes.right.cx, eyes.right.cy, c.x, c.y, MAX_HIGHLIGHT);
      tgtR = { px: pr.x, py: pr.y, hx: hr.x, hy: hr.y };
    }

    function animate() {
      curL.px += (tgtL.px - curL.px) * LERP;
      curL.py += (tgtL.py - curL.py) * LERP;
      curL.hx += (tgtL.hx - curL.hx) * LERP;
      curL.hy += (tgtL.hy - curL.hy) * LERP;
      curR.px += (tgtR.px - curR.px) * LERP;
      curR.py += (tgtR.py - curR.py) * LERP;
      curR.hx += (tgtR.hx - curR.hx) * LERP;
      curR.hy += (tgtR.hy - curR.hy) * LERP;

      pupilL.setAttribute('cx', String(curL.px));
      pupilL.setAttribute('cy', String(curL.py));
      pupilR.setAttribute('cx', String(curR.px));
      pupilR.setAttribute('cy', String(curR.py));
      highlightL.setAttribute('cx', String(curL.hx));
      highlightL.setAttribute('cy', String(curL.hy));
      highlightR.setAttribute('cx', String(curR.hx));
      highlightR.setAttribute('cy', String(curR.hy));

      const settled = Math.abs(curL.px - tgtL.px) < 0.05
        && Math.abs(curL.py - tgtL.py) < 0.05
        && Math.abs(curR.px - tgtR.px) < 0.05
        && Math.abs(curR.py - tgtR.py) < 0.05;

      if (settled && !active) { running = false; return; }
      requestAnimationFrame(animate);
    }

    function start() { if (!running) { running = true; requestAnimationFrame(animate); } }

    document.addEventListener('mousemove', (e) => {
      active = true;
      updateTargets(e.pageX, e.pageY);
      start();
    });

    document.addEventListener('mouseleave', () => {
      active = false;
      tgtL = restTarget(eyes.left);
      tgtR = restTarget(eyes.right);
      start();
    });

    document.addEventListener('touchmove', (e) => {
      if (e.touches.length > 0) {
        active = true;
        updateTargets(e.touches[0].pageX, e.touches[0].pageY);
        start();
      }
    }, { passive: true });

    document.addEventListener('touchend', () => {
      active = false;
      tgtL = restTarget(eyes.left);
      tgtR = restTarget(eyes.right);
      start();
    });
  }
</script>

